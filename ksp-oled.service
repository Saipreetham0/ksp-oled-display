[Unit]
Description=KSP Electronics OLED Display
After=network.target

[Service]
ExecStart=/usr/bin/python3 /home/pi/ksp-oled-display/ksp_oled.py
WorkingDirectory=/home/pi/ksp-oled-display
StandardOutput=journal
StandardError=journal
Restart=always
RestartSec=5
User=pi

[Install]
WantedBy=multi-user.target
